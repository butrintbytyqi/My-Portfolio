# Contact agent — set these in Netlify (Site configuration → Environment
# variables), scoped to "Functions". They are read only by the serverless
# function and are NEVER exposed to the browser. Copy to a local `.env`
# (git-ignored) if you run `netlify dev`.

# Google AI Studio key (https://aistudio.google.com/apikey) — free, no card.
GEMINI_API_KEY=

# Resend API key (https://resend.com/api-keys) — starts with re_
RESEND_API_KEY=

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile). The bot check
# activates only when BOTH keys below are set.
#   - Secret key: server-side only (Functions scope). Keep private.
TURNSTILE_SECRET_KEY=
#   - Site key: PUBLIC, baked into the frontend at build time (Builds scope).
#     Must be prefixed VITE_ to reach the client bundle.
VITE_TURNSTILE_SITE_KEY=

# Optional overrides (sensible defaults are baked into the function):
# CONTACT_OWNER=butrinti022@gmail.com
# CONTACT_FROM=Butrint Bytyqi <hello@butrintbytyqi.com>
# GEMINI_MODEL=gemini-2.5-flash
